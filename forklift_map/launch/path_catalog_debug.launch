<launch>
  <param name="/use_sim_time" value="false"/>

  <rosparam file="$(find forklift_map)/config/map_param.yaml" command="load"/>
  <rosparam file="$(find forklift_planner)/config/planner_param.yaml" command="load"/>

  <node name="forklift_map" pkg="forklift_map" type="map_node" output="screen"/>

  <node name="path_catalog_debug_node"
        pkg="forklift_map"
        type="path_catalog_debug_node"
        output="screen">
    <!-- true: A1/A2 are computed from B4/B5 and B60/B61 midpoints. -->
    <param name="use_exact_midpoints" value="true"/>

    <!-- Used only when use_exact_midpoints=false, kept for field tuning. -->
    <param name="a1_x" value="1.25"/>
    <param name="a1_y" value="4.38"/>
    <param name="a1_yaw" value="-1.57079632679"/>
    <param name="a2_x" value="1.25"/>
    <param name="a2_y" value="0.12"/>
    <param name="a2_yaw" value="1.57079632679"/>
  </node>

  <node name="rviz" pkg="rviz" type="rviz"
        args="-d $(find forklift_map)/config/forklift.rviz"
        required="false">
    <env name="LIBGL_ALWAYS_SOFTWARE" value="1"/>
    <env name="QT_X11_NO_MITSHM" value="1"/>
  </node>
</launch>
