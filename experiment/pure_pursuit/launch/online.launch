<?xml version="1.0"?>
<launch>
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find pure_pursuit)/launch/rviz.rviz"/>
    <node pkg="apriltag_localization" type="apriltag_localization_node" name="apriltag" />
    <node pkg="chassis" type="chassis_node" name="chassis" output="screen" />
    <node pkg="apriltag_localization" type="case_interface.py" name="interface" output="screen" />
    <node pkg="pure_pursuit" type="online_trajectory_publisher.py" name="plan" output="screen" />
    <node pkg="pure_pursuit" type="pure_pursuit_node" name="controller_0" output="screen">
        <param name="target" value="0" />
    </node>
    <node pkg="pure_pursuit" type="pure_pursuit_node" name="controller_1" output="screen">
        <param name="target" value="1" />
    </node>
    <node pkg="pure_pursuit" type="pure_pursuit_node" name="controller_2" output="screen">
        <param name="target" value="2" />
    </node>
</launch>
